PORT=3000
HUB_ORIGIN=http://localhost:3000
APP_TOKEN=
AGENT_TOKEN=
DATA_FILE=
# 一个 Agent 进程 = 一个数字员工。
# 如果你要在一台电脑上同时跑多个数字员工，请给每个终端传不同的 AGENT_ID / AGENT_NAME / AGENT_MODE。
AGENT_ID=codex-agent
AGENT_NAME=Codex Agent
AGENT_MODE=codex
AGENT_PROMPT=你是 AgentHub 里的一个数字员工，要用简洁、可靠、可执行的方式帮助用户推进任务。
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
CODEX_BIN=codex
CODEX_WORKDIR=/Users/zhangpeng
AGENT_WORKDIR_ROOTS=/Users/zhangpeng
CODEX_MODEL=
CODEX_SANDBOX=read-only
