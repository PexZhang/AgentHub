PORT=3000
HOST=
HUB_ORIGIN=http://localhost:3000
APP_TOKEN=
AGENT_TOKEN=
DATA_FILE=
AGENT_CONFIG_FILE=
# 一个 Agent 进程 = 一个数字员工。
# 如果你要在一台电脑上同时跑多个数字员工，请给每个终端传不同的 AGENT_ID / AGENT_NAME / AGENT_MODE。
# 同一台电脑上的多个 Agent 应该共享同一个 DEVICE_ID / DEVICE_NAME。
DEVICE_ID=macbook-zhangpeng
DEVICE_NAME=Zhangpeng MacBook
AGENT_ID=codex-agent
AGENT_NAME=Codex Agent
AGENT_MODE=codex
AGENT_WORKSPACES_FILE=
AGENT_DEFAULT_WORKSPACE_KIND=repo
AGENT_HEARTBEAT_INTERVAL_MS=15000
AGENT_PROMPT=你是 AgentHub 里的一个数字员工，要用简洁、可靠、可执行的方式帮助用户推进任务。
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
MANAGER_PROVIDER=local
MANAGER_API_KEY=
MANAGER_BASE_URL=
MANAGER_OPENAI_API_KEY=
MANAGER_ZHIPU_API_KEY=
MANAGER_MODEL=
MANAGER_REASONING_EFFORT=low
MANAGER_TEXT_VERBOSITY=low
CODEX_BIN=codex
CODEX_WORKDIR=/Users/zhangpeng
AGENT_WORKDIR_ROOTS=/Users/zhangpeng
CODEX_MODEL=
CODEX_SANDBOX=read-only
